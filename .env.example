# Distil environment — copy to .env and fill in per deployment.
# All VITE_* values ship in the client bundle: publishable-tier only, never
# service-role keys or other secrets.

# Supabase project (Dashboard → Settings → API)
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# Clinic this deployment belongs to (uuid from the clinics table). The
# unauthenticated /intake kiosk writes intakes to this clinic and refuses to
# submit if unset — every kiosk deployment MUST set it.
VITE_CLINIC_ID=00000000-0000-0000-0000-000000000000

# Optional: clinic branding printed on the kiosk intake PDF header. Blank
# values just omit the address/phone block — the header still renders.
VITE_CLINIC_NAME=
VITE_CLINIC_ADDRESS=
VITE_CLINIC_PHONE=
